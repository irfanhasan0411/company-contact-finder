# Optional: Brave Search API key (recommended for better results)
# Get free key at: https://api.search.brave.com/
BRAVE_API_KEY=

# Concurrency settings
MAX_WORKERS=20
REQUEST_TIMEOUT=15
RETRY_ATTEMPTS=3

# Auto-save interval (number of companies)
AUTOSAVE_INTERVAL=20

# Rate limiting (seconds between requests per domain)
RATE_LIMIT_DELAY=1.5

# Input/Output
INPUT_FILE=input/companies.xlsx
OUTPUT_FILE=output/companies_updated.xlsx
